{
  "uid": "red-metrics",
  "title": "RED Metrics",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (method, route, status_code) (rate(http_requests_total[1m]))",
          "legendFormat": "{{method}} {{route}} {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (method, route, status_code) (rate(http_requests_total{status_code=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{method}} {{route}} {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP P95 Latency",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Email Jobs Rate",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (job_type, status) (rate(email_jobs_total[5m]))",
          "legendFormat": "{{job_type}} / {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Email Job P95 Duration",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, job_type) (rate(email_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{job_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Scan Runs",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (status) (increase(scan_runs_total[1h]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GitHub API Request Rate",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (endpoint, status) (rate(github_api_requests_total[5m]))",
          "legendFormat": "{{endpoint}} / {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GitHub API P95 Duration",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(github_api_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    }
  ]
}
